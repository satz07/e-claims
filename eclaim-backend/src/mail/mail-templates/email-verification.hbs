<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>

    <style>
      * { box-sizing: border-box; } html, body { margin: 0; padding: 0; width:
      100% !important; overflow-x: hidden; background: #f6f7ff; font-family:
      Arial, Helvetica, sans-serif; color: #0f172a; } .wrap { width: 100%;
      padding: 24px 12px; } .card { width: 100%; max-width: 560px; margin: 0
      auto; background: #ffffff; border-radius: 14px; border: 1px solid #e9ecff;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08); overflow: hidden; }
      .topbar { height: 6px; background: #2f41db; } .content { padding: 24px
      20px; } .brand { display: flex; align-items: center; gap: 10px;
      margin-bottom: 18px; } .logo { width: 40px; height: 40px; border-radius:
      10px; border: 1px solid #e9ecff; } .brand-title { margin: 0; font-size:
      16px; font-weight: 700; } .brand-sub { margin: 2px 0 0; font-size: 12px;
      color: #64748b; } h2 { margin: 0 0 10px; font-size: 18px; } p { margin: 0
      0 12px; font-size: 14px; line-height: 1.6; color: #334155; } .code-box {
      margin: 20px 0; padding: 18px; border-radius: 12px; border: 2px dashed
      #2f41db; background: #f7f8ff; text-align: center; width: 100%; } .code {
      font-size: 26px; font-weight: 800; letter-spacing: 6px; /* reduced from
      8px to prevent overflow */ color: #2f41db; word-break: break-all; } .pill
      { display: inline-block; padding: 3px 12px; border-radius: 999px;
      background: #eef0ff; color: #2f41db; font-weight: 700; font-size: 12px; }
      .warning { margin-top: 12px; font-size: 13px; color: #b91c1c; } .footer {
      padding: 14px 20px 18px; font-size: 12px; color: #64748b; background:
      #fbfbff; border-top: 1px solid #eef0ff; text-align: center; } @media
      (max-width: 480px) { .content { padding: 20px 16px; } .code { font-size:
      22px; letter-spacing: 4px; } }
    </style>
  </head>

  <body>
    <div class='wrap'>
      <div class='card'>
        <div class='topbar'></div>

        <div class='content'>
          <div class='brand'>
            <img src='cid:{{logoCid}}' alt='{{app_name}} Logo' class='logo' />
            <div style='margin-left: 0.7rem;'>
              <p class='brand-title'>{{app_name}}</p>
              <p class='brand-sub'>Account Security</p>
            </div>
          </div>

          <h2>Verify Your Email</h2>

          <p>
            Hi
            <strong>{{username}}</strong>,<br /><br />
            Thank you for choosing
            <strong>{{app_name}}</strong>. Please use the verification code
            below to confirm your email address.
          </p>

          <div class='code-box'>
            <div class='code'>{{verificationCode}}</div>

            <p style='margin-top:14px;font-size:13px;'>
              This code expires in
              <span class='pill'>{{expiryMinutes}} minutes</span>.
            </p>
          </div>

          <p class='warning'>
            If you did not request this verification, you can safely ignore this
            email.
          </p>

          <p style='font-size:13px;'>
            For security reasons, never share this code with anyone.
          </p>
        </div>

        <div class='footer'>
          &copy;
          {{app_name}}. All rights reserved.
        </div>
      </div>
    </div>
  </body>
</html>