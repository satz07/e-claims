<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>

    <style>
      * { box-sizing: border-box; } html, body { margin: 0; padding: 0; width:
      100% !important; overflow-x: hidden; background: #f6f7ff; font-family:
      Arial, Helvetica, sans-serif; color: #0f172a; } .wrap { width: 100%;
      padding: 24px 12px; } .card { width: 100%; max-width: 560px; margin: 0
      auto; background: #ffffff; border-radius: 14px; border: 1px solid #e9ecff;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08); overflow: hidden; }
      .topbar { height: 6px; background: #2f41db; } .content { padding: 24px
      20px; } .brand { display: flex; align-items: center; gap: 10px;
      margin-bottom: 18px; } .logo { width: 40px; height: 40px; border-radius:
      10px; border: 1px solid #e9ecff; } .brand-title { margin: 0; font-size:
      16px; font-weight: 700; } .brand-sub { margin: 2px 0 0; font-size: 12px;
      color: #64748b; } h2 { margin: 0 0 10px; font-size: 18px; } p { margin: 0
      0 12px; font-size: 14px; line-height: 1.6; color: #334155; } .status-box {
      margin: 20px 0; padding: 16px; border-radius: 12px; border: 1px solid
      #e9ecff; background: #f7f8ff; } .pill { display: inline-block; padding:
      3px 12px; border-radius: 999px; background: #eef0ff; color: #2f41db;
      font-weight: 700; font-size: 12px; } .check { display: inline-block;
      width: 34px; height: 34px; border-radius: 10px; background: #eef0ff;
      color: #2f41db; font-weight: 900; line-height: 34px; text-align: center;
      margin-right: 10px; flex: 0 0 auto; } .row { display: flex; align-items:
      center; gap: 10px; } .footer { padding: 14px 20px 18px; font-size: 12px;
      color: #64748b; background: #fbfbff; border-top: 1px solid #eef0ff;
      text-align: center; } @media (max-width: 480px) { .content { padding: 20px
      16px; } }
    </style>
  </head>

  <body>
    <div class='wrap'>
      <div class='card'>
        <div class='topbar'></div>

        <div class='content'>
          <div class='brand'>
            <img src='cid:{{logoCid}}' alt='{{app_name}} Logo' class='logo' />
            <div style='margin-left: 0.7rem;'>
              <p class='brand-title'>{{app_name}}</p>
              <p class='brand-sub'>Verification Update</p>
            </div>
          </div>

          <h2>KYC Approved</h2>

          <p>
            Hi
            <strong>{{username}}</strong>,<br /><br />
            Your identity verification (KYC) has been successfully completed.
          </p>

          <div class='status-box'>
            <div class='row'>
              <div class='check'>✓</div>
              <div>
                <p style='margin:0 0 6px; font-weight:700; color:#0f172a;'>
                  Status:
                  <span class='pill'>Approved</span>
                </p>
                <p style='margin:0; font-size:13px; color:#475569;'>
                  You can now access all verified features in
                  <strong>{{app_name}}</strong>.
                </p>
              </div>
            </div>
          </div>

          <p style='font-size:13px;'>
            If you did not initiate this verification or believe this is a
            mistake, please contact our support team immediately.
          </p>
        </div>

        <div class='footer'>
          &copy;
          {{app_name}}. All rights reserved.
        </div>
      </div>
    </div>
  </body>
</html>