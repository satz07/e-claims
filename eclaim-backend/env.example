# =============================================================================
# ddsc-service — Environment Variables Template
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_PORT=3000
APP_NAME=ddsc-service
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=nestjs

# -----------------------------------------------------------------------------
# Redis — REQUIRED
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# -----------------------------------------------------------------------------
# JWT (RS256) — REQUIRED
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
# Paste the PEM content as a single line, replacing real newlines with \n
# -----------------------------------------------------------------------------
JWT_ALG=RS256
JWT_ISSUER=your-issuer
JWT_AUDIENCE=your-audience
JWT_EXPIRES=15m
JWT_KID=
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES=7d

# -----------------------------------------------------------------------------
# Keycloak — REQUIRED
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
REALM=your-realm
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
CLIENT_SCOPE=openid

# -----------------------------------------------------------------------------
# File Storage — REQUIRED
# Set FILE_DRIVER=local for local storage (no AWS keys needed)
# Set FILE_DRIVER=s3  to use AWS S3 (fill keys below)
# -----------------------------------------------------------------------------
FILE_DRIVER=local

# AWS S3 (only required when FILE_DRIVER=s3)
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_DEFAULT_S3_BUCKET=
AWS_DEFAULT_S3_URL=
AWS_S3_REGION=

# -----------------------------------------------------------------------------
# Mail — REQUIRED
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_DEFAULT_EMAIL=no-reply@example.com
MAIL_DEFAULT_NAME=DDSC Service
MAIL_IGNORE_TLS=false
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false

# -----------------------------------------------------------------------------
# Sumsub (KYC) — REQUIRED
# -----------------------------------------------------------------------------
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_ROOT_URL=https://api.sumsub.com
SUMSUB_LEVEL_NAME=basic-kyc-level

# -----------------------------------------------------------------------------
# DFNS (Wallet / Blockchain) — REQUIRED
# DFNS_PRIVATE_KEY must be a PEM key (same \n escaping as JWT keys above)
# -----------------------------------------------------------------------------
DFNS_APP_ID=
DFNS_ORG_ID=
DFNS_ORG_EMAIL=
DFNS_BASE_URL=https://api.dfns.io
DFNS_AUTH_TOKEN=
DFNS_CREDENTIAL_ID=
DFNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
DFNS_RP_ID=localhost
DFNS_RP_NAME=DDSC
DFNS_PERMISSION_ID=
DFNS_PERMISSION_NAME=
DFNS_ENFORCE_END_USER_WALLETS=false
DFNS_TOKEN_CONTRACT=
DFNS_TOKEN_DECIMALS=18
DFNS_NETWORK=EthereumSepolia

# -----------------------------------------------------------------------------
# DTPS (Cards) — REQUIRED
# -----------------------------------------------------------------------------
DTPS_BASE_URL=https://api.dtps.example.com
DTPS_API_KEY=
DTPS_SECRET_KEY=

# -----------------------------------------------------------------------------
# FAB (First Abu Dhabi Bank) — REQUIRED
# -----------------------------------------------------------------------------
FAB_TOKEN_URL=https://example.fab.com/oauth/token
FAB_PAYMENT_URL=https://example.fab.com/payment
FAB_CLIENT_ID=
FAB_CLIENT_ASSERTION=
FAB_AES_KEY=
FAB_CHANNEL_ID=
FAB_ACCOUNT_INFO_URL=
FAB_TXN_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# WebAuthn (Passkeys) — REQUIRED
# Multiple values are comma-separated
# -----------------------------------------------------------------------------
WEBAUTHN_RP_NAME=DDSC
WEBAUTHN_ALLOWED_ORIGIN=http://localhost:3000
WEBAUTHN_ALLOWED_RPID=localhost

# -----------------------------------------------------------------------------
# Social OAuth (Optional)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
APPLE_APP_AUDIENCE=

# -----------------------------------------------------------------------------
# TNT Auth — Optional
# -----------------------------------------------------------------------------
TNT_AUTH_URL=

# -----------------------------------------------------------------------------
# E-Claims / Spearhead blockchain anchoring
# -----------------------------------------------------------------------------
BACKEND_PORT=8001
SPEARHEAD_RPC_URL=https://rpc.spearhead.adifoundation.ai
CHAIN_ID=99991
CLAIM_REGISTRY_ADDRESS=0xA8eFbf955496518D6e3Cb10ABC90627671534088
PROVIDER_REGISTRY_ADDRESS=0xeda747a951502878079a789DA5D3380dA6Ec2276
# Hex private key (no 0x prefix ok) — must match ClaimRegistry owner(); funds ADI for gas
CITIZEN_REGISTRY_ADDRESS=0xd646829b3310a17B660079acc7F4A97DBFC9ce2D
CLINICIAN_REGISTRY_ADDRESS=0x64e8Ffca1907B0769Bf02cB60DC62D0e1070a591
INSURER_REGISTRY_ADDRESS=0xe8729132b31c0e1E7683360A4781A3307fb52163
# Set false to skip facility/citizen/scheme checks during FHIR submit (dev only)
REGISTRY_VALIDATION_ENABLED=true
